# .env.example — copiar a .env y completar
GROQ_API_KEY=tu_api_key_aqui
OPENAI_API_KEY=              # solo si LLM_PROVIDER=openai
LLM_PROVIDER=groq            # groq | openai | ollama
LLM_MODEL=llama-3.1-8b-instant
# Para OpenAI: LLM_PROVIDER=openai y LLM_MODEL=gpt-4o-mini (API de pago; el default Groq es gratuito)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=banco_web
CHUNK_SIZE=512               # CHUNK_SIZE está en PALABRAS (no tokens ni caracteres)
CHUNK_OVERLAP=64
HISTORY_WINDOW_N=6           # N mensajes anteriores (requisito)
TOP_K=8
RERANK_TOP_K=3
# BBVA (https://www.bbva.com.co/) prohíbe crawling en su robots.txt; se usa Bancolombia (la prueba permite otro banco)
SCRAPE_BASE_URL=https://www.bancolombia.com/
SCRAPE_MAX_PAGES=50
DB_PATH=conversations.db
